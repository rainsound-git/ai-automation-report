# Notion インテグレーション設定
# https://www.notion.so/my-integrations でトークンを取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 監視するデータベースの ID
# Notion でデータベースを開き、URL の末尾 32 桁（ハイフンなし）をコピー
# 例: https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ ← これ
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE Messaging API チャネルアクセストークン
# LINE Developers Console でチャネル作成後、「Messaging API設定」タブで発行
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 通知の送信先 ID（ユーザーIDまたはグループID）
# ユーザーID: LINE Developers Console の「あなたのユーザーID」、または Webhook で取得
LINE_TARGET_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Pages で公開したレポートの URL（LINE メッセージに含まれる）
# 例: https://yourname.github.io/ai-automation-report/notion1/
REPORT_URL=https://yourname.github.io/ai-automation-report/notion1/

# 何日分の更新を取得するか（省略時: 1）
REPORT_DAYS=1

# 更新がなくても LINE 通知する場合は true
NOTIFY_ALWAYS=false
